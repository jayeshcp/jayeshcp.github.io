<style>
  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 4px;
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
  }

  /* Shared shimmer sweep */
  .btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.08) 40%, rgba(255,255,255,0.15) 50%, rgba(255,255,255,0.08) 60%, transparent 100%);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .btn:hover::before {
    transform: translateX(100%);
  }

  /* LinkedIn */
  .btn-linkedin {
    background: #0A66C2;
    color: #fff;
    border: 1px solid #0A66C2;
    box-shadow: 0 0 0 0 rgba(10, 102, 194, 0);
  }
  .btn-linkedin:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(10, 102, 194, 0.45), 0 0 0 1px #0A66C2;
  }
  .btn-linkedin:active {
    transform: translateY(0px);
  }

  /* GitHub */
  .btn-github {
    background: #0d0d0d;
    color: #e8e8e8;
    border: 1px solid rgba(255,255,255,0.18);
    box-shadow: inset 0 0 0 0 rgba(255,255,255,0.04);
  }
  .btn-github:hover {
    transform: translateY(-2px);
    background: #0d0d0d;
    border-color: rgba(255,255,255,0.35);
    box-shadow: 0 8px 24px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.12);
    color: #fff;
  }
  .btn-github:active {
    transform: translateY(0px);
  }

  /* Icon pulse on hover */
  .btn:hover svg {
    animation: icon-pop 0.3s ease forwards;
  }
  @keyframes icon-pop {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.2);
    }
    100% {
      transform: scale(1.05);
    }
  }
</style>