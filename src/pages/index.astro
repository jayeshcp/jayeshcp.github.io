  label: string;
  level: number; // Proficiency level from 1 to 5
}

const technicalSkills: Skill[] = [
  {
    label: "React",
    level: 5,
  },
  {
    label: "TypeScript",
    level: 5,
  },
  {
    label: "JavaScript",
    level: 5,
  },
  {
    label: "Node.js",
    level: 5,
  },
  {
    label: "Express",
    level: 5,
  },
  {
    label: "NestJS",
    level: 5,
  },
  {
    label: "Jest",
    level: 5,
  },
  {
    label: "Playwright",
    level: 5,
  },
  {
    label: "Cucumber BDD",
    level: 5,
  },
  {
    label: "Jasmine",
    level: 5,
  },
  {
    label: "GCP",
    level: 3,
  },
  {
    label: "AWS",
    level: 3,
  },
  {
    label: "Docker",
    level: 5,
  },
  {
    label: "Kubernetes",
    level: 4,
  },
  {
    label: "CircleCI",
    level: 5,
  },
  {
    label: "Harness",
    level: 3,
  },
  {
    label: "MongoDB",
    level: 3,
  },
  {
    label: "PostgreSQL",
    level: 5,
  },
  {
    label: "Supabase",
    level: 4,
  },
  {
    label: "Pocketbase",
    level: 5,
  },
  {
    label: "MySQL",
    level: 3,
  },
  {
    label: "HTML",
    level: 5,
  },
  {
    label: "CSS",
    level: 5,
  },
  {
