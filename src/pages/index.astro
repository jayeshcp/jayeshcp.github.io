---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>👋 Hi there!</h1>
      <p>
        Welcome to my personal website, blog, and portfolio built with Astro.
      </p>

      <p class="mt-12 text-xl font-bold">Some of my technical skills are:</p>
      <p class="text-sm italic">Highlighted skills are the most recent ones</p>
      <ul class="ml-4 mt-8 grid grid-cols-3 gap-4">
        {
          technicalSkills.map((skill: Skill) => (
            <li>
              ↠{" "}
              <span
                class={`px-2 py-1 ${skill.level >= 5 ? "bg-green-200 rounded" : ""}`}
                title={`Proficiency level: ${skill.level}/5`}
              >
                {skill.label}
              </span>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>
