---

---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content="{{ settings.description }}"/>
    <meta name="author" content="{{ settings.author }}"/>
    <title>{{ settings.title }}</title>
    <link rel="stylesheet" href="/assets/css/style.css"/>
  </head>
  <body>
    <div class="container min-w-80 mx-auto">
      <header>
        <h1 class="text-4xl font-bold mb-4">
          <a href="/">{{ settings.title }}</a>
        </h1>
        <p>{{ settings.description }}</p>

        <nav>
          <ul class="navigation">
            {% for item in navigation %}
              <li>
                <a href="{{ item.url | url }}">{{ item.label }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      </header>

      <main class="content mb-40">
        {{ content | safe }}
      </main>

      <footer class="text-center py-2 text-xs text-gray-600 bg-slate-50 border-t border-slate-200 fixed inset-x-0 bottom-0">
        <div>&copy; {{ page.date.getFullYear() }}
          {{ settings.author }}. All rights reserved. Site version: {{ site.version }}</div>
        <div>Generated with Eleventy v{{ site.eleventyVersion }}.</div>
      </footer>
    </div>

    <script src="/assets/js/script.js"></script>
  </body>
</html>