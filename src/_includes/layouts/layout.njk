---

---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content="{{ settings.description }}"/>
    <meta name="author" content="{{ settings.author }}"/>
    <link rel="icon" href="{{ '/assets/images/favicon.png' | url }}"/>
    <title>{{ settings.title }}</title>
    {% if env.isProd %}
      <link rel="stylesheet" href="{{ '/assets/css/style.css' | bust }}">
    {% else %}
      <link rel="stylesheet" href="{{ '/assets/css/style.css' }}">
    {% endif %}

  </head>
  <body>
    <div class="container min-w-80 mx-auto">
      <header>
        <h1 class="text-4xl font-bold mb-4">
          <a href="/">{{ settings.title }}</a>
        </h1>
        <p>{{ settings.description }}</p>

        <nav>
          <ul class="navigation">
            {% for item in navigation %}
              <li>
                <a href="{{ item.url | url }}">{{ item.label }}</a>
              </li>
            {% endfor %}
          </ul>
        </nav>
      </header>

      <main class="content mb-40">
        {{ content | safe }}
      </main>

      <footer class="text-center py-2 text-xs text-gray-600 bg-slate-50 border-t border-slate-200 fixed inset-x-0 bottom-0">
        <div>&copy; {{ page.date.getFullYear() }}
          {{ settings.author }}. All rights reserved. Site version: {{ site.version }}</div>
        <div>Generated with Eleventy v{{ site.eleventyVersion }}.</div>
      </footer>
    </div>

    {% if env.isProd %}
      <script src="{{ '/assets/js/script.js' | bust }}"></script>
    {% else %}
      <script src="{{ '/assets/js/script.js' }}"></script>
    {% endif %}

    {% if env.GTAG and env.isProd %}
      <!-- Google tag (gtag.js) -->
      <script async src="https://www.googletagmanager.com/gtag/js?id={{ env.GTAG }}"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag('js', new Date());

        gtag('config', '{{ env.GTAG }}');
      </script>
    {% endif %}
  </body>
</html>